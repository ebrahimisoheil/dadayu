# Copy to .env and fill in real values. Never commit .env.

# ── Postgres (main data DB) ───────────────────────────────────────────────────
DADAYU_PG_HOST=dadayu_postgres
DADAYU_PG_PORT=5432
DADAYU_PG_DB=dadayu
DADAYU_PG_USER=dadayu
DADAYU_PG_PASSWORD=changeme

# ── Postgres (Dagster metadata DB) ────────────────────────────────────────────
DAGSTER_PG_HOST=dadayu_postgres
DAGSTER_PG_PORT=5432
DAGSTER_PG_DB=dagster
DAGSTER_PG_USER=dagster
DAGSTER_PG_PASSWORD=changeme

# ── Cube API ──────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
CUBE_API_SECRET=changeme_generate_with_openssl_rand_hex_32

# Set to "false" in production to disable the Cube playground UI
CUBEJS_DEV_MODE=true
